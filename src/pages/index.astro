  <script>
    // Header scroll state
    const hdr = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      hdr.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Intersection observer for fade-up
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Waveform canvas
    (function() {
      const canvas = document.getElementById('waveCanvas');
      const ctx = canvas.getContext('2d');
      let width, height, frame = 0;

      function resize() {
        width = canvas.width = canvas.offsetWidth;
        height = canvas.height = canvas.offsetHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      const WAVES = [
        { freq: 0.018, amp: 0.10, speed: 0.006, alpha: 0.6, lineWidth: 1.5 },
        { freq: 0.024, amp: 0.06, speed: 0.009, alpha: 0.35, lineWidth: 1 },
        { freq: 0.012, amp: 0.15, speed: 0.004, alpha: 0.2, lineWidth: 0.75 },
      ];

      // heartbeat pulse shape
      function heartbeatY(x, w, h, t, wave) {
        const progress = (x / w + t * wave.speed) % 1;
        const base = Math.sin(progress * Math.PI * 2 * w * wave.freq) * wave.amp * h;
        // add sharp spike every ~0.7 units
        const pulse = progress % 0.7;
        let spike = 0;
        if (pulse < 0.03) spike = pulse / 0.03 * 0.12 * h;
        else if (pulse < 0.06) spike = (0.06 - pulse) / 0.03 * 0.12 * h;
        else if (pulse < 0.09) spike = -(pulse - 0.06) / 0.03 * 0.08 * h;
        else if (pulse < 0.12) spike = -(0.12 - pulse) / 0.03 * 0.08 * h;
        return h / 2 + base + spike;
      }

      function drawWave(wave) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(212, 115, 90, ${wave.alpha})`;
        ctx.lineWidth = wave.lineWidth;
        for (let x = 0; x <= width; x += 2) {
          const y = heartbeatY(x, width, height, frame, wave);
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      function animate() {
        ctx.clearRect(0, 0, width, height);
        WAVES.forEach(drawWave);
        frame++;
        requestAnimationFrame(animate);
      }
      animate();
    })();

    // Waitlist
    function handleWaitlist(inputId = null) {
      const input = inputId
        ? document.getElementById(inputId)
        : document.querySelector('.hero-cta .hero-input');
      const email = input ? input.value.trim() : '';
      if (!email || !email.includes('@')) {
        if (input) { input.style.borderColor = 'var(--rose)'; setTimeout(() => input.style.borderColor = '', 1500); }
        return;
      }
      // Replace button with confirmation
      const btn = input ? input.nextElementSibling : null;
      if (btn) {
        btn.textContent = 'On the list ✓';
        btn.style.background = 'transparent';
        btn.style.color = 'var(--rose)';
        btn.style.borderColor = 'var(--rose)';
        btn.disabled = true;
      }
      input.value = '';
      input.placeholder = 'You\'re on the list.';
    }
  </script>

