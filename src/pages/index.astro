---
// This is the frontmatter script area in Astro. 
// You can import components like a React PleasureBar here later.
---

<html lang="en">
  <<script src="https://cdn.tailwindcss.com"></script>>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>EDGE | The EmotionOS for Human Connection</title>
  </head>
  <body class="bg-neutral-950 text-neutral-50 font-sans antialiased selection:bg-fuchsia-500 selection:text-white">
    
    <header class="fixed top-0 w-full flex justify-between items-center px-8 py-6 z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-900">
      <div class="text-2xl font-bold tracking-widest uppercase">
        EDGE
      </div>
      <nav class="hidden md:flex gap-8 text-sm font-medium text-neutral-400">
        <a href="#vision" class="hover:text-white transition-colors">Vision</a>
        <a href="#tech" class="hover:text-white transition-colors">The Tech</a>
        <a href="#privacy" class="hover:text-white transition-colors">Privacy</a>
      </nav>
      <button class="px-5 py-2 text-sm font-semibold rounded-full bg-neutral-800 hover:bg-neutral-700 transition-colors">
        Investor Deck
      </button>
    </header>

    <main class="relative min-h-screen flex flex-col justify-center items-center px-6 overflow-hidden">
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[300px] bg-fuchsia-600/20 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 max-w-4xl mx-auto text-center mt-20">
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-400 to-cyan-400">EmotionOS</span> <br /> 
          for Human Connection.
        </h1>
        
        <p class="text-lg md:text-xl text-neutral-400 mb-12 max-w-2xl mx-auto leading-relaxed">
          Decoding physiological signals into real-time guidance for mutual pleasure, empathy, and emotional flow. The missing link isn't desire—it's data.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="w-full sm:w-80 px-6 py-4 rounded-full bg-neutral-900 border border-neutral-800 focus:outline-none focus:border-fuchsia-500 transition-colors text-white placeholder-neutral-500"
          />
          <button class="w-full sm:w-auto px-8 py-4 rounded-full bg-gradient-to-r from-fuchsia-500 to-cyan-500 text-white font-bold tracking-wide hover:opacity-90 transition-opacity">
            Join the Waitlist
          </button>
        </div>
      </div>

      <div class="relative z-10 mt-24 w-full max-w-3xl h-2 bg-neutral-900 rounded-full overflow-hidden">
        <div class="absolute left-1/2 top-0 h-full w-32 -translate-x-1/2 bg-white/10 rounded-full"></div>
        <div class="absolute left-[45%] top-0 h-full w-2 bg-fuchsia-500 shadow-[0_0_15px_rgba(217,70,239,0.8)]"></div>
      </div>
      <p class="mt-4 text-xs tracking-widest text-neutral-500 uppercase">Locking into the Pleasure Zone</p>
      
    </main>

  </body>
</html>
